// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        Int      @id@default(autoincrement())
  name      String
  email     String   @unique
  password  String
  posts     Posts[]
  games     Games[]
  comments  Comments[]
  pressedPosts PressedPosts[]
  pressedComments PressedComments[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Posts {
  id       Int    @id@default(autoincrement())
  title    String
  content  String?
  gameTag  String?
  like     Int    @default(0)
  user     Users  @relation(fields: [userId], references:[id], onDelete:Cascade)
  userId   Int
  comments Comments[]
  pressedPosts PressedPosts[]
  pressedComments PressedComments[]
  rankFlg  Boolean   @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Games {
  id     Int     @id@default(autoincrement())
  name   String  
  rank   String? 
  user   Users   @relation(fields: [userId], references:[id], onDelete:Cascade)
  userId Int     
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comments {
  id          Int      @id@default(autoincrement())
  comment     String
  like        Int      @default(0)
  bad         Int      @default(0)
  post        Posts    @relation(fields:[postId], references:[id], onDelete:Cascade)
  postId      Int
  user        Users    @relation(fields:[userId], references:[id], onDelete:Cascade)
  userId      Int
  pressedComments PressedComments[]
  hiddenFlg   Boolean  @default(false)
  dispRankFlg Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PressedPosts {
  id         Int      @id@default(autoincrement())
  post       Posts    @relation(fields:[postId], references:[id], onDelete:Cascade)
  postId     Int
  user       Users    @relation(fields:[userId], references:[id], onDelete:Cascade)
  userId     Int
  pressFlg   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PressedComments {
  id          Int      @id@default(autoincrement())
  comment     Comments @relation(fields:[commentId], references:[id], onDelete:Cascade)
  commentId   Int
  post        Posts    @relation(fields:[postId], references:[id], onDelete:Cascade)
  postId      Int
  user        Users    @relation(fields:[userId], references:[id], onDelete:Cascade)
  userId      Int
  pressedFlg  Boolean  @default(false)
  pressedType String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}